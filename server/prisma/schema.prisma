generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id               Int        @id @default(autoincrement())
  name             String
  email            String     @unique
  password         String
  age              Int
  gender           String
  height_cm        Float
  weight_kg        Float
  goal             String
  activity_level   String
  tdee_kcal        Int
  target_kcal      Int
  protein_target_g Int
  carbs_target_g   Int
  fat_target_g     Int
  fiber_target_g   Int
  water_target     Int
  cuisine          String     @default("kerala")
  meals            Meal[]
  progress         Progress[]
  dailyLogs        DailyLog[]
  workouts         Workout[]
  created_at       DateTime   @default(now())
}

model Meal {
  id          Int      @id @default(autoincrement())
  user_id     Int
  user        User     @relation(fields: [user_id], references: [id])
  meal_type   String
  description String
  items       String
  total_kcal  Int
  protein_g   Float
  carbs_g     Float
  fat_g       Float
  fiber_g     Float
  logged_at   DateTime @default(now())
}

model DailyLog {
  id              Int      @id @default(autoincrement())
  user_id         Int
  user            User     @relation(fields: [user_id], references: [id])
  date            DateTime
  total_kcal      Int      @default(0)
  total_protein_g Float    @default(0)
  total_carbs_g   Float    @default(0)
  total_fat_g     Float    @default(0)
  total_fiber_g   Float    @default(0)
  water_glasses   Int      @default(0)

  @@unique([user_id, date], name: "user_daily_unique")
}

model Progress {
  id          Int      @id @default(autoincrement())
  user_id     Int
  user        User     @relation(fields: [user_id], references: [id])
  weight_kg   Float?
  waist_cm    Float?
  hip_cm      Float?
  notes       String?
  recorded_at DateTime @default(now())
}

model KeralaFood {
  id        Int    @id @default(autoincrement())
  name      String @unique
  alias     String?
  kcal_per  Float
  protein_g Float
  carbs_g   Float
  fat_g     Float
  fiber_g   Float
  serving   String
}

model Workout {
  id        Int      @id @default(autoincrement())
  user_id   Int
  user      User     @relation(fields: [user_id], references: [id])
  exercise  String
  sets      Int
  reps      Int
  weight_kg Float?
  notes     String?
  logged_at DateTime @default(now())
}
